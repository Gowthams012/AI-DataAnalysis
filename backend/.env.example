# ── LLM Provider ──────────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/anthropic/claude-3-haiku
GROQ_API_KEY=
GROQ_MODEL=groq/llama-3.3-70b-versatile



# ── Server ─────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:5174"]

# ── Limits ─────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
MAX_FILES_PER_SESSION=10
MAX_ROWS_PREVIEW=5
MAX_CONTEXT_ROWS=100
MAX_CONVERSATION_HISTORY=20
CODE_EXECUTION_TIMEOUT=30

# ── Database & Supabase ──────────────────────────────────────
DATABASE_URL="postgresql://postgres.username:password@aws-0-ap-southeast-2.pooler.supabase.com:6543/postgres?sslmode=require"
SUPABASE_URL="https://username.supabase.co"
SUPABASE_KEY=
JWT_SECRET=
